# Copy this file to .env and fill in your values

SESSION_SECRET=replace-with-any-long-random-string
ADMIN_PASSWORD=replace-with-your-admin-password
TG_TOKEN=replace-with-your-telegram-bot-token
TG_CHAT=replace-with-your-telegram-chat-id

# Only needed in production (leave empty for local dev)
# ALLOWED_ORIGINS=https://yoursite.pages.dev,https://yourdomain.com
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
